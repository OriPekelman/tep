<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>tep chat</title>
  <style>
    * { box-sizing: border-box; }
    body { font: 15px/1.4 -apple-system, sans-serif; max-width: 720px; margin: 1em auto; padding: 0 1em; color: #222; }
    nav  { display: flex; align-items: center; gap: 1em; padding-bottom: .5em; border-bottom: 1px solid #ddd; }
    h1   { font-size: 1.3em; margin: 0; }
    #who { color: #888; font-size: .9em; flex: 1; }
    #me  { padding: .25em .5em; }
    #log { height: 60vh; overflow-y: auto; border: 1px solid #ddd; padding: 1em; margin: 1em 0; background: #fafafa; border-radius: 4px; }
    .msg { padding: 4px 0; }
    .msg .a { color: #36c; font-weight: bold; }
    .msg .t { color: #aaa; font-size: .8em; margin-left: .5em; }
    form { display: flex; gap: .5em; }
    #body { flex: 1; padding: .5em; }
    button { padding: .5em 1em; }
    .status { color: #888; font-size: .85em; margin: .5em 0; }
  </style>
</head>
<body>
  <nav>
    <h1>tep chat</h1>
    <span id="who">connecting...</span>
    <input id="me" placeholder="your name">
  </nav>

  <div id="log"></div>
  <p class="status" id="conn">stream: idle</p>

  <form id="f">
    <input id="body" placeholder="say something..." autocomplete="off">
    <button>send</button>
  </form>

  <script>
    // The framework hands us the highest message id at page-load
    // time so we don't replay the entire history on first connect.
    let sinceId  = <%= @last_id %>;
    let me       = localStorage.getItem('tep_chat_user') || '';
    document.getElementById('me').value = me;
    document.getElementById('me').addEventListener('change', e => {
      me = e.target.value.trim();
      localStorage.setItem('tep_chat_user', me);
      heartbeat();
    });

    const log    = document.getElementById('log');
    const conn   = document.getElementById('conn');
    const who    = document.getElementById('who');

    function escape(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    function append(m) {
      const row = document.createElement('div');
      row.className = 'msg';
      row.innerHTML = '<span class="a">' + escape(m.author) + ':</span> ' + escape(m.body);
      log.appendChild(row);
      log.scrollTop = log.scrollHeight;
      sinceId = Math.max(sinceId, m.id);
    }

    function connectStream() {
      conn.textContent = 'stream: connecting (since=' + sinceId + ')';
      const es = new EventSource('/chat/stream?since=' + sinceId);
      es.onopen = () => { conn.textContent = 'stream: live'; };
      es.onmessage = (e) => {
        try { append(JSON.parse(e.data)); } catch(_) {}
      };
      es.onerror = () => {
        conn.textContent = 'stream: reconnecting...';
        es.close();
        // Server caps connections at STREAM_MAX -- the close is
        // expected; reconnect with the latest sinceId so we don't
        // miss anything that landed during the few-ms gap.
        setTimeout(connectStream, 250);
      };
    }

    async function heartbeat() {
      if (!me) return;
      const fd = new FormData();
      fd.set('user', me);
      try { await fetch('/chat/heartbeat', { method: 'POST', body: fd }); } catch(_) {}
    }

    async function refreshWho() {
      try {
        const r = await fetch('/chat/who');
        const list = await r.json();
        if (list.length === 0) {
          who.textContent = 'no one online';
        } else {
          who.textContent = list.length + ' online: ' + list.map(p => p.user).join(', ');
        }
      } catch(_) {}
    }

    document.getElementById('f').addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!me) { alert('set a name first'); return; }
      const body = document.getElementById('body');
      const text = body.value.trim();
      if (!text) return;
      const fd = new FormData();
      fd.set('author', me);
      fd.set('body', text);
      await fetch('/chat/send', { method: 'POST', body: fd });
      body.value = '';
    });

    connectStream();
    setInterval(heartbeat, 5000);
    setInterval(refreshWho, 5000);
    heartbeat(); refreshWho();
  </script>
</body>
</html>
