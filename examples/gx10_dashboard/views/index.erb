<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="refresh" content="30">
  <title>gx10 · <%= @host %></title>
  <link rel="icon" type="image/svg+xml" href="/logo.svg">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <header class="bar">
    <h1>
      <img src="/logo.svg" alt="" class="logo">
      gx10 dashboard
    </h1>
    <div class="who">
      <span><%= @user %></span>
      <form method="post" action="/logout" class="inline"><button>log out</button></form>
    </div>
  </header>

  <section class="strip">
    <div><span class="lbl">host</span> <%= @host %></div>
    <div><span class="lbl">uptime</span> <%= @uptime %></div>
    <div><span class="lbl">load (1/5/15m)</span> <%= @load %></div>
    <div><span class="lbl">mem</span> <%= @mem_used %> used / <%= @mem_tot %> total (<%= @mem_avail %> free)</div>
  </section>

  <div class="grid three">
    <article class="card">
      <h2>GPU</h2>
      <pre><%= @gpu %></pre>
    </article>

    <article class="card">
      <h2>Inference backends</h2>
      <pre><%= @inference %></pre>
    </article>

    <article class="card">
      <h2>tmux sessions</h2>
      <pre><%= @tmux %></pre>
    </article>
  </div>

  <div class="grid">
    <article class="card wide">
      <h2>Running docker</h2>
      <pre><%= @docker %></pre>
    </article>
  </div>

  <div class="grid two">
    <article class="card">
      <h2>Sites in ~/sites</h2>
      <table class="rows">
        <% @sites.split("\n").each do |line| %>
          <% parts = line.split("\t") %>
          <tr><th><%= parts[0] %></th><td><%= parts[1] || "" %></td></tr>
        <% end %>
      </table>
    </article>

    <article class="card">
      <h2>Operator todo list</h2>
      <form method="post" action="/todos" class="add">
        <input name="body" placeholder="what's on your mind?" autocomplete="off" required>
        <button>add</button>
      </form>
      <ul class="todos">
        <% @todos.split("\n").each do |line| %>
          <% if line.length > 0 %>
            <% parts = line.split("\t") %>
            <% id   = parts[0] %>
            <% done = parts[1] %>
            <% body = parts[2] || "" %>
            <li class="<%= done == "1" ? "done" : "open" %>">
              <form method="post" action="/todos/<%= id %>/toggle" class="inline">
                <button class="check"><%= done == "1" ? "x" : "·" %></button>
              </form>
              <span class="body"><%= body %></span>
              <form method="post" action="/todos/<%= id %>/delete" class="inline">
                <button class="rm">×</button>
              </form>
            </li>
          <% end %>
        <% end %>
      </ul>
    </article>
  </div>

  <p class="apilinks">
    bearer-token API: <code>POST /api/token</code> · <code>GET /api/status</code> · <code>GET /api/todos</code> · <code>GET /api/events</code> (SSE)
    · snapshot: <a href="/snapshot.md">system-state.md</a>
  </p>

  <%= @footer %>
</body>
</html>
