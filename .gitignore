# Build artefacts -- the C helper, compiled examples, and translator
# scratch files all live alongside the sources but never want to be
# checked in.
lib/tep/*.o
examples/hello
examples/sinatra_style
examples/websocket_echo
examples/pg_hello
examples/.*.tep.rb
bench/hello_bench
bench/api_bench
bench/pg_bench
bench/pg_pool_bench
bench/.*.tep.rb
bench/Gemfile.lock
test/real_world/0[0-9]_*
test/real_world/.*.tep.rb
!test/real_world/0[0-9]_*.rb

# `bin/tep run app.rb` drops a binary at the repo root.
tep-run-bin

# Built examples + scratch DBs from the blog / chat showcases.
examples/blog/.*.tep.rb
examples/blog/*.db
examples/blog/blog
examples/chat/.*.tep.rb
examples/chat/*.db
examples/chat/chat
examples/gx10_dashboard/.*.tep.rb
examples/gx10_dashboard/*.db
examples/gx10_dashboard/gx10dash

# Stray spinel-built binaries from running `spinel some.tep.rb`
# directly (the default output strips `.rb`, leaving a `.tep`).
*.tep
.*.tep

# tep scratch + built binaries under any example subdir (gem examples
# build `<dir>/.app.tep.rb` next to app.rb, then `<dir>/app`).
examples/*/.*.tep.rb
examples/*/app

# tep's own gem artefacts.
*.gem
pkg/
.bundle/
Gemfile.lock

# Gem examples (examples/<x>/Gemfile): the Gemfile + Gemfile.lock are the
# source of truth and ARE committed (override the global Gemfile.lock
# ignore above). The gem source under vendor/spinel is GENERATED from the
# lock by `spinel-compat vendor` (make vendor-examples) -- not committed.
!examples/*/Gemfile.lock
examples/*/vendor/

# Editor / OS noise.
.DS_Store
*.swp
.idea/
.vscode/

# Per-project AI assistant context (local-only; the canonical file
# lives on the Mac and is rsynced to gx10). Public repo doesn't ship it.
CLAUDE.md

# Optional spinel --emit-rbs output (rake rbs:emit, dev-only)
sig/.emitted/
