# PBKDF2-SHA256 password hashing, self-describing storage format.
module Tep
  class Password
    # Hash `plain` with PBKDF2-SHA256 (200k iters by default). Returns
    # a self-describing string `pbkdf2_sha256$<iters>$<salt_b64url>$<derived_b64url>`
    # suitable for direct storage; `verify` parses the same format.
    def self.hash: (String plain) -> String

    # Constant-time verification against a `hash`-shaped stored value.
    # Returns `false` on any structural or signature mismatch.
    def self.verify: (String plain, String stored) -> bool

    # Internal: split a `$`-separated 4-part stored string.
    def self.split4: (String s) -> Array[String]
  end
end
