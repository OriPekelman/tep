# Percent-decoding + form-urlencoded query parser.
module Tep
  class Url
    # "%41+b" -> "A b". Decodes %XX escapes and `+` -> space.
    def self.unescape: (String s) -> String

    # Percent-encode bytes unsafe in cookie values, query strings, and
    # similar contexts. RFC 3986 unreserved set is left intact;
    # everything else becomes `%XX` (uppercase hex).
    def self.escape: (String s) -> String

    # Integer 0..15 -> uppercase hex character.
    def self.hex_char: (Integer n) -> String

    # Single hex character -> integer 0..15, or -1 if invalid.
    def self.hex_nibble: (String c) -> Integer

    # Split a URL into a str=>str hash with keys:
    #   "scheme", "host", "port", "path", "query"
    # `query` is the raw substring after `?` (no further decoding).
    # Default port follows the scheme (80/http, 443/https).
    def self.split_url: (String u) -> Hash[String, String]

    # "a=1&b=2&c" -> {"a"=>"1","b"=>"2","c"=>""}
    def self.parse_query: (String s) -> Hash[String, String]
  end
end
