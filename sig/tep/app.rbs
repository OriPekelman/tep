# Framework-wide singleton. Holds the route router, current
# before/after filters, asset bundle, session secret, and the
# cooperative scheduler's parallel state arrays. Accessed as
# `Tep::APP` throughout the framework.
module Tep
  class App
    attr_accessor router: Tep::Router
    attr_accessor static_root: String
    attr_accessor session_secret: String

    # Filter / not-found handlers. Defaults are Tep::Filter.new /
    # Tep::Handler.new (no-op base classes). Subclasses installed
    # via the DSL.
    attr_accessor before_filter: Tep::Filter
    attr_accessor after_filter: Tep::Filter
    attr_accessor nf_handler: Tep::Handler

    # Build-time asset bundle. `path` -> bytes / mime.
    attr_accessor asset_bodies: Hash[String, String]
    attr_accessor asset_mimes: Hash[String, String]

    # Scheduler-side parallel arrays. One slot per fiber.
    attr_accessor sched_fibers: Array[Tep::FiberSlot]
    attr_accessor sched_wake_at: Array[Integer]
    attr_accessor sched_current: Integer
    attr_accessor sched_io_fd: Array[Integer]
    attr_accessor sched_io_mode: Array[Integer]
    attr_accessor sched_io_ready: Array[Integer]

    # Hand-off stash for Tep::Server::Scheduled (closure-capture
    # workaround; see lib/tep/app.rb).
    attr_accessor pending_listen_fd: Integer
    attr_accessor pending_client_fd: Integer
    attr_accessor pending_quiet: bool

    # Tep::Job background-worker idempotency flag for the chatbot
    # demo (see examples/chatbot/app.rb's JobWorker).
    attr_accessor user_bg_started: bool

    def initialize: () -> void

    def add_asset: (String path, String body, String mime) -> String

    # Take the signed-cookie secret. "" disables signing (also the
    # default; sessions become per-request scratch only).
    def set_session_secret: (String s) -> String

    def add_route: (String verb, String pattern, Tep::Handler handler) -> Array[Tep::Route]
    def set_static_root: (String root) -> String
    def set_before: (Tep::Filter f) -> Tep::Filter
    def set_after: (Tep::Filter f) -> Tep::Filter
    def set_not_found: (Tep::Handler h) -> Tep::Handler

    # Walk the router for a matching route, run before/after filters,
    # apply session round-trip. Returns the response body lines.
    def dispatch: (Tep::Request req, Tep::Response res) -> Array[String]

    def try_static: (Tep::Request req, Tep::Response res) -> bool

    def self.guess_mime: (String path) -> String
  end
end
