# Minimal levelled logger -- stderr or file destination.
module Tep
  class Logger
    attr_accessor min_level: String
    attr_accessor file_path: String

    def initialize: () -> void

    # Level name is one of: "debug", "info", "warn", "error". Unknown
    # labels are treated as "info" by `should_log?`.
    def set_level: (String name) -> String

    # Path to append to. Empty string routes back to stderr.
    def to_file: (String path) -> String
    def to_stderr: () -> String

    def debug: (String msg) -> void
    def info:  (String msg) -> void
    def warn:  (String msg) -> void
    def error: (String msg) -> void

    # `level` and `msg` are both strings; `level` is the call-site
    # label (matches `set_level` vocab), not an Integer.
    def log: (String level, String msg) -> void

    def should_log?: (String level) -> bool

    # Class-level numeric mapping for the four known labels (debug=0,
    # info=1, warn=2, error=3). Unknown labels return 1 (info).
    def self.level_value: (String name) -> Integer

    # "[<unix_seconds>] [<level>] <message>"
    def format_line: (String level, String msg) -> String
  end
end
